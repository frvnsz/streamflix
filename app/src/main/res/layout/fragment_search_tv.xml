<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.search.SearchTvFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_search"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="100dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="100dp"
        android:background="@drawable/bg_search_edittext"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.streamflixreborn.streamflix.keyboard.WheelKeyboardView
            android:id="@+id/wheel_keyboard"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/ll_global_search"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/ll_global_search"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_btn_exoplayer_tv"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        android:nextFocusDown="@id/vgv_search"
        app:layout_constraintEnd_toEndOf="@id/cl_search"
        app:layout_constraintStart_toStartOf="@id/cl_search"
        app:layout_constraintTop_toBottomOf="@id/cl_search">

        <TextView
            android:id="@+id/tv_global_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/global_search"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/iv_global_search_switch"
            android:layout_width="48dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_switch_off"
            tools:ignore="ContentDescription" />

    </LinearLayout>

    <androidx.leanback.widget.VerticalGridView
        android:id="@+id/vgv_search"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_global_search"
        tools:listitem="@layout/item_movie_tv" />

    <include
        android:id="@+id/is_loading"
        layout="@layout/layout_is_loading_tv"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@id/vgv_search"
        app:layout_constraintEnd_toEndOf="@id/vgv_search"
        app:layout_constraintStart_toStartOf="@id/vgv_search"
        app:layout_constraintTop_toTopOf="@id/vgv_search" />

</androidx.constraintlayout.widget.ConstraintLayout>